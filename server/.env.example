# Server Config
PORT=3000
NODE_ENV=development

# Database Config (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lockin

# Cache & State Config (Redis)
REDIS_URL=redis://localhost:6379

# Security Config
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production
JWT_EXPIRES_IN=30d

# Razorpay Config
RAZORPAY_KEY_ID=rzp_test_change_me
RAZORPAY_KEY_SECRET=rzp_secret_change_me
RAZORPAY_WEBHOOK_SECRET=rzp_webhook_secret_change_me

# Firebase Cloud Messaging Config
# Path to service account JSON file, or inline JSON string
FIREBASE_SERVICE_ACCOUNT_PATH=configs/firebase-service-account.json

# Google OAuth Config
GOOGLE_CLIENT_ID=your_google_web_client_id_placeholder.apps.googleusercontent.com
